# frozen_string_literal: true

D = Steep::Diagnostic

# rbs-inline and rbs_rails walk the bundled gems under vendor/ and dump mirror
# signatures into sig/generated/vendor/ and sig/rbs_rails/vendor/. Those
# duplicate gems whose real signatures come from the RBS collection and
# reference gem-internal types that do not resolve (RBS::UnknownTypeName).
# They are gitignored noise, so load every generated subtree except `vendor/`.
non_vendor = lambda do |root|
  Dir.glob("#{root}/*").reject { |path| File.basename(path) == 'vendor' }.sort
end

# Rails framework signatures come from the RBS collection (rbs_collection.yaml),
# model/route signatures from sig/rbs_rails (`rake rbs_rails:all`), application
# and test code from sig/generated (rbs-inline), Devise from sig/handwritten,
# and the Minitest/Rails declarative test DSL from sig/test_shim.
#
# `app` and `test` are separate targets so the permissive test-DSL shim only
# relaxes the tests, never the application code.

target :app do
  check 'app'

  non_vendor.call('sig/generated').each { |path| signature path }
  non_vendor.call('sig/rbs_rails').each { |path| signature path }
  signature 'sig/handwritten'

  configure_code_diagnostics(D::Ruby.default)
end

target :test do
  check 'test'

  non_vendor.call('sig/generated').each { |path| signature path }
  non_vendor.call('sig/rbs_rails').each { |path| signature path }
  signature 'sig/handwritten'
  signature 'sig/test_shim'

  library 'minitest'

  configure_code_diagnostics(D::Ruby.default)
end
