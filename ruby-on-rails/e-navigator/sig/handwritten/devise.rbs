# Hand-written shim for the Devise surface the gem collection does NOT cover.
#
# The RBS collection (devise/4.9) already declares the six Devise controller
# classes as `Devise::*Controller < ::DeviseController` plus a bare top-level
# `class DeviseController` stub and the model mix-in modules. Redeclaring the
# controllers here would clash with that (RBS::SuperclassMismatchError), so
# this shim only adds what the collection omits:
#
#   * the parameter sanitizer,
#   * the controller helpers Devise mixes into every controller at runtime via
#     `ActiveSupport.on_load(:action_controller)`, and
#   * the Action Controller ancestry of `DeviseController` (the collection
#     leaves the stub bare), so the app's `Users::*Controller` subclasses
#     resolve Action Controller methods.

module Devise
  # `Devise.mappings` (used by ApplicationHelper) and the `Devise::Mapping`
  # value it returns are not modelled by the collection.
  def self.mappings: () -> ::Hash[::Symbol, ::Devise::Mapping]

  class Mapping
  end

  class ParameterSanitizer
    def permit: (untyped name, *untyped, **untyped) -> untyped

    def sanitize: (untyped name) -> untyped
  end

  module Controllers
    module Helpers
      def authenticate_user!: (*untyped) -> void

      def user_signed_in?: () -> bool

      def current_user: () -> untyped

      def signed_in?: (?untyped scope) -> bool

      def devise_controller?: () -> bool

      def devise_parameter_sanitizer: () -> ::Devise::ParameterSanitizer

      def sign_in: (*untyped) -> void

      def sign_out: (*untyped) -> untyped

      def bypass_sign_in: (untyped resource, ?scope: untyped) -> void
    end
  end
end

# The collection declares `class DeviseController end` as a bare stub (Devise's
# controllers descend from it). Reopening it here to pin the configured parent
# controller is conflict-free because the collection's declaration omits a
# superclass, and it gives the app's `Users::*Controller < Devise::*Controller`
# subclasses their Action Controller ancestry.
class DeviseController < ::ActionController::Base
end

# Devise mixes its controller helpers into every Action Controller.
module ActionController
  class Base
    include ::Devise::Controllers::Helpers
  end
end
