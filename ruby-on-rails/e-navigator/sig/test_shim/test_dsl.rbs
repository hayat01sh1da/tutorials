# Hand-written shim for the test-only DSL surface that has no RBS in the gem
# collection: the Minitest/Rails declarative test DSL, request/integration
# helpers, Devise test helpers and the route helpers tests rely on. Loaded
# only by the `:test` Steep target, so it never relaxes type checking of
# application code.
#
# Steep evaluates the declarative `test "..." do ... end` / `setup` blocks
# with `self` typed as the test class singleton, and assertions cascade as
# plain calls. Singleton classes are Objects, so declaring the DSL on
# `::Object` as permissive `untyped` methods makes it resolve in every
# context (instance, singleton, Object) — mirroring the approach used for the
# other apps in this workspace.

# `ActionMailer::TestCase` ships no RBS in the collection. It behaves as an
# `ActiveSupport::TestCase` (declarative `test`, assertions and fixtures all
# come from there / Minitest, which the collection does provide).
module ActionMailer
  class TestCase < ::ActiveSupport::TestCase
  end
end

# The collection types the `default` class macro as `-> void`; the mailer
# test reads it back as a hash (`ApplicationMailer.default[:from]`). Override
# the reader form for the test target only.
class ApplicationMailer
  def self.default: (*untyped) -> untyped
end

# Devise's test integration modules are not in the collection. They are
# mixed into the test base classes in test/test_helper.rb and provide the
# `sign_in` / `sign_out` authentication helpers.
module Devise
  module Test
    module IntegrationHelpers
      def sign_in: (*untyped) -> void

      def sign_out: (*untyped) -> void
    end

    module ControllerHelpers
      def sign_in: (*untyped) -> void

      def sign_out: (*untyped) -> void
    end
  end
end

# ---------------------------------------------------------------------------
# Permissive test DSL, evaluated with `self` as a test-class singleton.
# ---------------------------------------------------------------------------
class Object
  # Route helpers (`*_path` / `*_url`) generated by rbs_rails. They are mixed
  # into `ActionController::Base` for application code; tests call them from
  # the declarative-block context, so expose them here too.
  include ::_RbsRailsPathHelpers

  # Minitest / ActiveSupport / Rails assertions
  def assert: (*untyped) ?{ () -> untyped } -> untyped

  def assert_not: (*untyped) ?{ () -> untyped } -> untyped

  def assert_equal: (*untyped) -> untyped

  def assert_nil: (*untyped) -> untyped

  def assert_not_nil: (*untyped) -> untyped

  def assert_includes: (*untyped) -> untyped

  def assert_not_includes: (*untyped) -> untyped

  def assert_match: (*untyped) -> untyped

  def assert_no_match: (*untyped) -> untyped

  def assert_in_delta: (*untyped) -> untyped

  def assert_instance_of: (*untyped) -> untyped

  def assert_kind_of: (*untyped) -> untyped

  def assert_respond_to: (*untyped) -> untyped

  def assert_predicate: (*untyped) -> untyped

  def assert_empty: (*untyped) -> untyped

  def assert_not_empty: (*untyped) -> untyped

  def assert_same: (*untyped) -> untyped

  def assert_operator: (*untyped) -> untyped

  def assert_difference: (*untyped) ?{ () -> untyped } -> untyped

  def assert_no_difference: (*untyped) ?{ () -> untyped } -> untyped

  def assert_changes: (*untyped) ?{ () -> untyped } -> untyped

  def assert_no_changes: (*untyped) ?{ () -> untyped } -> untyped

  def assert_raises: (*untyped) ?{ () -> untyped } -> untyped

  def assert_nothing_raised: (*untyped) ?{ () -> untyped } -> untyped

  def assert_response: (*untyped) -> untyped

  def assert_redirected_to: (*untyped) -> untyped

  def assert_template: (*untyped) -> untyped

  def assert_select: (*untyped) ?{ () -> untyped } -> untyped

  def refute: (*untyped) ?{ () -> untyped } -> untyped

  def flunk: (*untyped) -> untyped

  def pass: (*untyped) -> untyped

  def skip: (*untyped) -> untyped

  # Test / fixture configuration DSL
  def fixtures: (*untyped) -> void

  def _process_action_callbacks: (*untyped) -> untyped

  # Integration request DSL
  def get: (*untyped) -> untyped

  def post: (*untyped) -> untyped

  def put: (*untyped) -> untyped

  def patch: (*untyped) -> untyped

  def delete: (*untyped) -> untyped

  def head: (*untyped) -> untyped

  def follow_redirect!: (*untyped) -> untyped

  def response: () -> untyped

  def request: () -> untyped

  def cookies: () -> untyped

  def session: () -> untyped

  def flash: () -> untyped

  def assigns: (*untyped) -> untyped

  # Devise authentication helpers (mixed into the test base classes at runtime)
  def sign_in: (*untyped) -> void

  def sign_out: (*untyped) -> void

  def devise_mapping: () -> untyped

  # ActiveSupport time-travel helpers
  def travel: (*untyped) ?{ () -> void } -> untyped

  def travel_to: (*untyped) ?{ () -> void } -> untyped

  def travel_back: () ?{ () -> void } -> untyped

  def freeze_time: () ?{ () -> void } -> untyped

  # Model accessors / predicates exercised on records (and nilable lookups)
  # in the tests. Permissive so `Interview | nil` / `nil` receivers resolve.
  def reload: (*untyped) -> untyped

  def status: () -> untyped

  def user: () -> untyped

  def approved?: () -> bool

  def declined?: () -> bool

  def approved!: () -> untyped

  def declined!: () -> untyped
end
