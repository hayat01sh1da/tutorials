# Hand-written shim for the test-only DSL surface that has no RBS in the
# gem collection: the Rails integration/system test base classes, the
# FactoryBot definition + usage DSL, Capybara, and the project's own test
# helpers. Loaded only by the `:test` Steep target, so it never relaxes
# type checking of application code.
#
# Steep evaluates test file bodies, FactoryBot.define blocks and example
# blocks with `self` typed as `::Object`, so the DSL is declared there as
# permissive `untyped` methods (mirroring the approach used for the other
# apps in this workspace).

# ---------------------------------------------------------------------------
# Rails test base classes. The actionpack collection declares these as
# `IntegrationTest < ActiveSupport::TestCase` and
# `SystemTestCase < ActiveSupport::TestCase`; the superclasses below must
# match those exactly (RBS::SuperclassMismatchError otherwise). We only reopen
# them to add the permissive request / Capybara DSL the tests rely on.
# ---------------------------------------------------------------------------
module ActionDispatch
  class IntegrationTest < ::ActiveSupport::TestCase
    include ::_RbsRailsPathHelpers

    def get: (*untyped) -> untyped

    def post: (*untyped) -> untyped

    def put: (*untyped) -> untyped

    def patch: (*untyped) -> untyped

    def delete: (*untyped) -> untyped

    def head: (*untyped) -> untyped

    def follow_redirect!: (*untyped) -> untyped

    def response: () -> untyped

    def request: () -> untyped

    def cookies: () -> untyped
  end

  class SystemTestCase < ::ActiveSupport::TestCase
    def self.driven_by: (*untyped) ?{ (untyped option) -> void } -> void

    # Capybara DSL
    def visit: (*untyped) -> untyped

    def click_on: (*untyped) -> untyped

    def click_link: (*untyped) -> untyped

    def click_button: (*untyped) -> untyped

    def fill_in: (*untyped) -> untyped

    def select: (*untyped) -> untyped

    def choose: (*untyped) -> untyped

    def check: (*untyped) -> untyped

    def uncheck: (*untyped) -> untyped

    def accept_confirm: (*untyped) ?{ () -> void } -> untyped

    def dismiss_confirm: (*untyped) ?{ () -> void } -> untyped

    def page: () -> untyped

    def find: (*untyped) -> untyped

    def assert_selector: (*untyped) -> untyped

    def assert_no_selector: (*untyped) -> untyped

    def assert_text: (*untyped) -> untyped

    def assert_no_text: (*untyped) -> untyped

    def assert_current_path: (*untyped) -> untyped
  end
end

# ---------------------------------------------------------------------------
# FactoryBot
# ---------------------------------------------------------------------------
module FactoryBot
  def self.define: () ?{ () -> void } -> void
end

# ---------------------------------------------------------------------------
# DSL evaluated with `self == ::Object` (FactoryBot.define / factory blocks,
# project test helpers, and assertions that cascade as Object calls)
# ---------------------------------------------------------------------------
class Object
  # Route helpers (`*_path` / `*_url`) generated by rbs_rails; tests call them
  # from the declarative-block context, where `self` is the test singleton.
  include ::_RbsRailsPathHelpers

  # FactoryBot definition DSL
  def factory: (*untyped) ?{ () -> void } -> void

  def sequence: (*untyped) ?{ (*untyped) -> untyped } -> untyped

  def association: (*untyped) -> untyped

  def trait: (*untyped) ?{ () -> void } -> void

  def transient: () ?{ () -> void } -> void

  def initialize_with: (*untyped) ?{ () -> untyped } -> void

  def to_create: () ?{ (untyped) -> untyped } -> void

  # Factory attribute setters referenced bare in the factory definitions
  def owner: (*untyped) ?{ () -> untyped } -> untyped

  def event_owner: (*untyped) ?{ () -> untyped } -> untyped

  def event: (*untyped) ?{ () -> untyped } -> untyped

  def provider: (*untyped) ?{ () -> untyped } -> untyped

  def start_at: (*untyped) ?{ () -> untyped } -> untyped

  def end_at: (*untyped) ?{ () -> untyped } -> untyped

  # FactoryBot usage DSL (mixed into tests via FactoryBot::Syntax::Methods)
  def build: (*untyped) -> untyped

  def build_stubbed: (*untyped) -> untyped

  def create: (*untyped) -> untyped

  def create_list: (*untyped) -> untyped

  def attributes_for: (*untyped) -> untyped

  # Ruby 3.4 implicit block parameter `it` — Steep 1.10 misparses it as a
  # method call, so make it resolve to untyped.
  def it: () -> untyped

  # Project auth/test helpers and time travel
  def sign_in_as: (*untyped) -> untyped

  def current_user: () -> untyped

  def travel_to: (*untyped) ?{ () -> void } -> untyped

  def travel: (*untyped) ?{ () -> void } -> untyped

  def freeze_time: () ?{ () -> void } -> untyped

  # Minitest/Rails declarative test DSL (`setup do ... end`, `test "..." do`)
  # is evaluated with `self` as the test class singleton.
  def setup: (*untyped) ?{ () -> void } -> void

  def teardown: (*untyped) ?{ () -> void } -> void

  # Minitest / ActiveSupport / Rails assertions
  def assert: (*untyped) ?{ () -> untyped } -> untyped

  def assert_not: (*untyped) ?{ () -> untyped } -> untyped

  def assert_equal: (*untyped) -> untyped

  def assert_nil: (*untyped) -> untyped

  def assert_not_nil: (*untyped) -> untyped

  def assert_includes: (*untyped) -> untyped

  def assert_not_includes: (*untyped) -> untyped

  def assert_match: (*untyped) -> untyped

  def assert_no_match: (*untyped) -> untyped

  def assert_in_delta: (*untyped) -> untyped

  def assert_instance_of: (*untyped) -> untyped

  def assert_kind_of: (*untyped) -> untyped

  def assert_respond_to: (*untyped) -> untyped

  def assert_predicate: (*untyped) -> untyped

  def assert_empty: (*untyped) -> untyped

  def assert_not_empty: (*untyped) -> untyped

  def assert_same: (*untyped) -> untyped

  def assert_operator: (*untyped) -> untyped

  def assert_difference: (*untyped) ?{ () -> untyped } -> untyped

  def assert_no_difference: (*untyped) ?{ () -> untyped } -> untyped

  def assert_changes: (*untyped) ?{ () -> untyped } -> untyped

  def assert_no_changes: (*untyped) ?{ () -> untyped } -> untyped

  def assert_raises: (*untyped) ?{ () -> untyped } -> untyped

  def assert_nothing_raised: (*untyped) ?{ () -> untyped } -> untyped

  def assert_response: (*untyped) -> untyped

  def assert_redirected_to: (*untyped) -> untyped

  def assert_template: (*untyped) -> untyped

  def assert_select: (*untyped) ?{ () -> untyped } -> untyped

  def refute: (*untyped) ?{ () -> untyped } -> untyped

  def flunk: (*untyped) -> untyped

  def pass: (*untyped) -> untyped

  def skip: (*untyped) -> untyped

  # Integration request DSL
  def get: (*untyped) -> untyped

  def post: (*untyped) -> untyped

  def put: (*untyped) -> untyped

  def patch: (*untyped) -> untyped

  def delete: (*untyped) -> untyped

  def head: (*untyped) -> untyped

  def follow_redirect!: (*untyped) -> untyped

  def response: () -> untyped

  def request: () -> untyped

  def cookies: () -> untyped

  def session: () -> untyped

  def flash: () -> untyped

  def assigns: (*untyped) -> untyped

  # Capybara DSL (system test declarative blocks + SignInHelper)
  def visit: (*untyped) -> untyped

  def click_on: (*untyped) -> untyped

  def click_link: (*untyped) -> untyped

  def click_button: (*untyped) -> untyped

  def fill_in: (*untyped) -> untyped

  def choose: (*untyped) -> untyped

  def check: (*untyped) -> untyped

  def uncheck: (*untyped) -> untyped

  def accept_confirm: (*untyped) ?{ () -> void } -> untyped

  def dismiss_confirm: (*untyped) ?{ () -> void } -> untyped

  def page: () -> untyped

  def assert_selector: (*untyped) -> untyped

  def assert_no_selector: (*untyped) -> untyped

  def assert_text: (*untyped) -> untyped

  def assert_no_text: (*untyped) -> untyped

  def assert_current_path: (*untyped) -> untyped

  # Devise-style auth helpers
  def sign_in: (*untyped) -> void

  def sign_out: (*untyped) -> void

  # ActiveSupport duration extensions, also reachable on nilable factory
  # values (`rand(1..30).days` => `(Integer | nil)#days`).
  def days: () -> untyped

  def hours: () -> untyped

  def minutes: () -> untyped

  def seconds: () -> untyped

  def weeks: () -> untyped
end

# OmniAuth is configured in SignInHelper but ships no RBS in the collection.
module OmniAuth
  def self.config: () -> untyped
end

# ---------------------------------------------------------------------------
# ActiveSupport duration core extensions used in factories
# ---------------------------------------------------------------------------
class Integer
  def days: () -> untyped

  def hours: () -> untyped

  def minutes: () -> untyped

  def seconds: () -> untyped

  def weeks: () -> untyped
end
